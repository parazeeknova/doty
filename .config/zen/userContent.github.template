.pagehead-actions summary.btn-sm.btn:hover,
.pagehead-actions a.btn-sm.btn:hover {
  background-color: color-mix(
    in srgb,
    var(--matugen-accent) 15%,
    var(--matugen-bg-dark)
  ) !important;
  color: var(--matugen-accent) !important;
  border-color: transparent !important;
  fill: var(--matugen-accent) !important;
}

/* All non-primary, non-invisible buttons in OverviewContent header. */
[class*="OverviewContent-module__Box_1"] button:not([data-variant="primary"]):not([data-variant="invisible"]),
