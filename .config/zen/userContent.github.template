    var(--matugen-accent) 10%,
    var(--matugen-bg-dark)
  ) !important;
}

td.react-directory-row-name-cell-small-screen,
td.react-directory-row-name-cell-large-screen,
td.react-directory-row-commit-cell {
  background-color: transparent !important;
