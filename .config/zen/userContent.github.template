  background-color: var(--matugen-bg-dark) !important;
  color: var(--matugen-fg) !important;
  border: none !important;
  border-color: transparent !important;
  fill: var(--matugen-fg) !important;
}
[class*="OverviewContent-module__Box_1"] button:not([data-variant="primary"]):not([data-variant="invisible"]):hover,
[class*="OverviewContent-module__Box_2"] button:not([data-variant="primary"]):not([data-variant="invisible"]):hover,
[class*="OverviewContent-module__Box_3"] button:not([data-variant="primary"]):not([data-variant="invisible"]):hover,
[class*="OverviewContent-module__Box_6"] button:not([data-variant="primary"]):not([data-variant="invisible"]):hover,
[class*="OverviewContent-module__Box_7"] button:not([data-variant="primary"]):not([data-variant="invisible"]):hover,
[class*="OverviewContent-module__Box_9"] button:not([data-variant="primary"]):not([data-variant="invisible"]):hover,
