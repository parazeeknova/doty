/* All non-primary, non-invisible buttons in pagehead-actions. */
.pagehead-actions button:not([data-variant="primary"]):not([data-variant="invisible"]),
.pagehead-actions summary.btn-sm.btn,
.pagehead-actions a.btn-sm.btn {
