/* ============================================================
 * GitHub (no @-moz-document wrapper — these rules are injected
 * into the content document via the Matugen JSWindowActor child
 * as a <style> element, and @-moz-document only works in
 * Firefox userContent.css, NOT in injected stylesheets).
 *
 * The actor child only injects this CSS when the document
 * hostname matches a supported site (currently github.com and
 * its subdomains). The bridge reads both this file and the
 * global matugen-userstyles.css and serves them keyed by
 * hostname.
 *
 * Strategy: override GitHub's high-level Primer design tokens
 * (--color-canvas-*, --color-fg-*, --color-accent-*, etc.) on
 * the root element. GitHub's own CSS consumes these vars
 * everywhere, so a small set of overrides themes the whole
 * site. The matugen palette doesn't have a red/danger, so
 * danger stays on a neutral rose that works for both dark and
 * light matugen palettes.
 * ============================================================ */

/* Smooth color transitions when the matugen theme switches.
 * Applies to every element so a wallpaper change fades the
 * whole page from one palette to the next. */
html,
body,
.Layout,
.application-main,
*,
*::before,
*::after {
  transition:
    background-color 0.35s ease,
    color 0.35s ease,
    border-color 0.35s ease,
    fill 0.35s ease,
    stroke 0.35s ease,
    box-shadow 0.35s ease !important;
}

:root,
html[data-color-mode] {
  /* Surfaces / backgrounds */
  --color-canvas-default: var(--matugen-bg-dark) !important;
  --color-canvas-subtle: var(--matugen-bg) !important;
  --color-canvas-inset: var(--matugen-bg-dark) !important;
  --color-canvas-overlay: var(--matugen-bg) !important;
  --color-canvas-primary: var(--matugen-bg) !important;

  /* Text */
  --color-fg-default: var(--matugen-fg) !important;
  --color-fg-muted: var(--matugen-fg-light) !important;
  --color-fg-subtle: var(--matugen-fg-light) !important;
  --color-fg-on-emphasis: var(--matugen-bg-dark) !important;
  --color-fg-link: var(--matugen-accent) !important;

  /* Accent (links, primary buttons, mentions, focus rings) */
  --color-accent-fg: var(--matugen-accent) !important;
  --color-accent-emphasis: var(--matugen-accent) !important;
  --color-accent-muted: color-mix(in srgb, var(--matugen-accent) 35%, transparent) !important;
  --color-accent-subtle: color-mix(in srgb, var(--matugen-accent) 12%, transparent) !important;
  --color-accent-contrast: var(--matugen-bg-dark) !important;

  /* Primary buttons */
  --color-btn-primary-bg: var(--matugen-accent) !important;
  --color-btn-primary-hover-bg: color-mix(in srgb, var(--matugen-accent) 88%, var(--matugen-fg) 12%) !important;
  --color-btn-primary-active-bg: color-mix(in srgb, var(--matugen-accent) 78%, var(--matugen-fg) 20%) !important;
  --color-btn-primary-text: var(--matugen-bg-dark) !important;
  --color-btn-primary-border: var(--matugen-accent) !important;
  --color-btn-primary-hover-border: var(--matugen-accent) !important;
  --color-btn-primary-active-border: var(--matugen-accent) !important;
  --color-btn-primary-disabled-bg: color-mix(in srgb, var(--matugen-accent) 40%, transparent) !important;
  --color-btn-primary-disabled-border: color-mix(in srgb, var(--matugen-accent) 40%, transparent) !important;
  --color-btn-primary-disabled-text: var(--matugen-bg-dark) !important;
  --color-btn-primary-icon: var(--matugen-bg-dark) !important;
  --color-btn-primary-hover-icon: var(--matugen-bg-dark) !important;
  --color-btn-primary-active-icon: var(--matugen-bg-dark) !important;

  /* Status: success (diff added, merged, passed) -> tertiary */
  --color-success-fg: var(--matugen-tertiary) !important;
  --color-success-emphasis: var(--matugen-tertiary) !important;
  --color-success-muted: color-mix(in srgb, var(--matugen-tertiary) 35%, transparent) !important;
  --color-success-subtle: color-mix(in srgb, var(--matugen-tertiary) 12%, transparent) !important;
  --color-success-contrast: var(--matugen-bg-dark) !important;

  /* Status: danger (diff removed, closed, failed) -> neutral rose.
   * matugen palette doesn't have red; this works on both dark
   * and light matugen palettes without clashing. */
  --color-danger-fg: #f5a3a3 !important;
  --color-danger-emphasis: #f08080 !important;
  --color-danger-muted: rgba(245, 163, 163, 0.35) !important;
  --color-danger-subtle: rgba(245, 163, 163, 0.12) !important;
  --color-danger-contrast: var(--matugen-bg-dark) !important;

  /* Status: attention (warning, draft) -> secondary */
  --color-attention-fg: var(--matugen-secondary) !important;
  --color-attention-emphasis: var(--matugen-secondary) !important;
  --color-attention-muted: color-mix(in srgb, var(--matugen-secondary) 35%, transparent) !important;
  --color-attention-subtle: color-mix(in srgb, var(--matugen-secondary) 12%, transparent) !important;
  --color-attention-contrast: var(--matugen-bg-dark) !important;

  /* Severe danger (errors) */
  --color-severe-fg: #f08080 !important;
  --color-severe-emphasis: #e06060 !important;
  --color-severe-muted: rgba(240, 128, 128, 0.35) !important;
  --color-severe-subtle: rgba(240, 128, 128, 0.12) !important;

  /* Done / sponsors (subtle accent-ish) */
  --color-done-fg: var(--matugen-tertiary) !important;
  --color-done-emphasis: var(--matugen-tertiary) !important;
  --color-done-muted: color-mix(in srgb, var(--matugen-tertiary) 35%, transparent) !important;
  --color-done-subtle: color-mix(in srgb, var(--matugen-tertiary) 12%, transparent) !important;

  /* Sponsors (pink in Catppuccin) */
  --color-sponsors-fg: #f5bde6 !important;
  --color-sponsors-emphasis: #f5bde6 !important;
  --color-sponsors-muted: rgba(245, 189, 230, 0.35) !important;
  --color-sponsors-subtle: rgba(245, 189, 230, 0.12) !important;

  /* Borders */
  --color-border-default: var(--matugen-bg-light) !important;
  --color-border-muted: color-mix(in srgb, var(--matugen-bg-light) 60%, transparent) !important;
  --color-border-subtle: color-mix(in srgb, var(--matugen-bg-light) 30%, transparent) !important;

  /* Diff blob (PR/commit view) */
  --color-diff-blob-addition-num-bg: color-mix(in srgb, var(--matugen-tertiary) 30%, transparent) !important;
  --color-diff-blob-addition-num-text: var(--matugen-fg) !important;
  --color-diff-blob-addition-line-bg: color-mix(in srgb, var(--matugen-tertiary) 15%, transparent) !important;
  --color-diff-blob-addition-word-bg: color-mix(in srgb, var(--matugen-tertiary) 30%, transparent) !important;
  --color-diff-blob-addition-word-text: var(--matugen-fg) !important;
  --color-diff-blob-deletion-num-bg: rgba(245, 163, 163, 0.3) !important;
  --color-diff-blob-deletion-num-text: var(--matugen-fg) !important;
  --color-diff-blob-deletion-line-bg: rgba(245, 163, 163, 0.15) !important;
  --color-diff-blob-deletion-word-bg: rgba(245, 163, 163, 0.3) !important;
  --color-diff-blob-deletion-word-text: var(--matugen-fg) !important;
  --color-diff-blob-hunk-num-bg: color-mix(in srgb, var(--matugen-accent) 40%, transparent) !important;
  --color-diff-blob-expander-icon: var(--matugen-fg-light) !important;
  --color-diff-blob-empty-num-bg: var(--matugen-bg) !important;
  --color-diff-blob-empty-line-bg: var(--matugen-bg) !important;

  /* Contribution graph */
  --color-calendar-graph-day-bg: var(--matugen-bg-light) !important;
  --color-calendar-graph-day-L1-bg: color-mix(in srgb, var(--matugen-accent) 40%, transparent) !important;
  --color-calendar-graph-day-L2-bg: color-mix(in srgb, var(--matugen-accent) 60%, transparent) !important;
  --color-calendar-graph-day-L3-bg: color-mix(in srgb, var(--matugen-accent) 80%, transparent) !important;
  --color-calendar-graph-day-L4-bg: var(--matugen-accent) !important;

  /* Mention chips */
  --color-user-mention-fg: var(--matugen-accent) !important;
  --color-user-mention-bg: color-mix(in srgb, var(--matugen-accent) 30%, transparent) !important;

  /* Page header / hero band */
  --color-page-header-bg: var(--matugen-bg) !important;

  /* Code blocks (lightweight override; full CodeMirror
   * theming is much bigger and out of scope for v1) */
  --color-markdown-code-bg: var(--matugen-bg) !important;

  /* Header bar */
  --color-header-bg: var(--matugen-bg-dark) !important;
  --color-header-fg: var(--matugen-fg) !important;
  --color-header-logo: var(--matugen-fg) !important;

  /* Top-level: ensures the OS theme picker doesn't fight us */
  accent-color: var(--matugen-accent) !important;
  color: var(--matugen-fg) !important;
}

/* Direct body/html/application backgrounds. GitHub's body
 * background-color doesn't always come from --color-canvas-default
 * (it can be set on a child layout element, or the body itself
 * can have an inline style), so we override the actual elements
 * directly with !important. The .application-main selector
 * covers GitHub's main content wrapper which carries the
 * primary surface color. */
html,
body,
.application-main,
.Layout,
.Layout-main,
.Layout-sidebar {
  background-color: var(--matugen-bg) !important;
  color: var(--matugen-fg) !important;
}

/* Headers and chrome (top navigation, etc.) */
.Header,
.AppHeader,
[role="banner"] {
  background-color: var(--matugen-bg-dark) !important;
  border-color: var(--matugen-bg-light) !important;
}

/* ============================================================
 * ELEMENT-LEVEL OVERRIDES
 * GitHub's Primer CSS doesn't always consume the
 * --color-* variables for actual rendered elements (a lot of
 * computed styles use scoped class names like .color-fg-default
 * or hardcoded hex). Override the elements directly so the
 * theme is visible regardless of whether the variables are
 * read by Primer.
 * ============================================================ */

/* Links: default + visited + hover. */
a,
.Link--primary,
.Link--secondary,
.Link--muted {
  color: var(--matugen-accent) !important;
}
a:hover,
.Link--primary:hover,
.Link--secondary:hover {
  color: color-mix(in srgb, var(--matugen-accent) 80%, var(--matugen-fg) 20%) !important;
}

/* Primary buttons (the green "Code" / "Pull request" etc.) */
.btn-primary,
.BtnGroup .btn-primary,
[data-variant="primary"] {
  background-color: var(--matugen-accent) !important;
  border-color: var(--matugen-accent) !important;
  color: var(--matugen-bg-dark) !important;
}
.btn-primary:hover,
.BtnGroup .btn-primary:hover {
  background-color: color-mix(in srgb, var(--matugen-accent) 88%, var(--matugen-fg) 12%) !important;
  border-color: color-mix(in srgb, var(--matugen-accent) 88%, var(--matugen-fg) 12%) !important;
  color: var(--matugen-bg-dark) !important;
}

/* Secondary / outline buttons */
.btn,
.btn-outline,
.BtnGroup-item {
  background-color: var(--matugen-bg-light) !important;
  border-color: var(--matugen-bg-light) !important;
  color: var(--matugen-fg) !important;
}
.btn:hover,
.btn-outline:hover,
.BtnGroup-item:hover {
  background-color: color-mix(in srgb, var(--matugen-bg-light) 85%, var(--matugen-fg) 15%) !important;
  border-color: color-mix(in srgb, var(--matugen-bg-light) 70%, var(--matugen-fg) 30%) !important;
}

/* Inline code and code blocks */
code,
pre,
.CodeMirror,
.markdown-body code,
.markdown-body pre {
  background-color: var(--matugen-bg) !important;
  color: var(--matugen-fg) !important;
  border-color: var(--matugen-bg-light) !important;
}

/* Borders — every Box, divider, table cell, etc. uses .border-* or border-color. */
.border,
.border-top,
.border-bottom,
.border-left,
.border-right,
.Box,
.Box-row,
.Box-header,
.Box-body,
.Box-footer,
.BorderGrid,
.BorderGrid-cell,
.divider,
hr {
  border-color: var(--matugen-bg-light) !important;
}

/* Cards and surface containers */
.Box,
.commit-tease,
.NewComment,
.TimelineItem,
.js-comment-container,
.discussion-timeline,
.file-navigation,
.Box--overlay,
.color-bg-default,
.color-bg-subtle,
.color-bg-emphasis {
  background-color: var(--matugen-bg) !important;
  color: var(--matugen-fg) !important;
}
.color-bg-emphasis {
  background-color: var(--matugen-accent) !important;
  color: var(--matugen-bg-dark) !important;
}

/* Muted text */
.color-fg-muted,
.color-fg-subtle,
.text-muted,
.Link--muted,
.text-gray,
.text-gray-dark,
.text-gray-light {
  color: var(--matugen-fg-light) !important;
}

/* Tab navigation underlinks (repo tabs: Code, Issues, PRs, ...) */
.UnderlineNav-item,
.tabnav-tabs .tabnav-tab {
  color: var(--matugen-fg) !important;
  border-color: transparent !important;
}
.UnderlineNav-item:hover,
.tabnav-tabs .tabnav-tab:hover {
  color: var(--matugen-accent) !important;
  border-color: var(--matugen-accent) !important;
}
.UnderlineNav-item.selected,
.tabnav-tabs .tabnav-tab.selected {
  color: var(--matugen-fg) !important;
  border-color: var(--matugen-accent) !important;
  border-bottom-color: var(--matugen-accent) !important;
}

/* Inputs / textareas / select */
input,
textarea,
select,
.form-control,
.InputGroup .form-control,
.color-bg-canvas {
  background-color: var(--matugen-bg) !important;
  color: var(--matugen-fg) !important;
  border-color: var(--matugen-bg-light) !important;
}

/* ============================================================
 * PROFILE / DASHBOARD ELEMENTS
 * Specific GitHub surfaces that don't pick up the generic
 * overrides: contribution graph, contribution activity,
 * pinned repos, dashboard cards.
 * ============================================================ */

/* Contribution graph wrapper and individual day cells. The
 * cells use --color-calendar-graph-day-* which we already
 * override, but the wrapper has a different bg that needs
 * its own override. The graph wrapper matches the page bg so
 * it blends in (no card look around the contribution squares). */
.graph-before-activity-overview,
.border.graph-before-activity-overview,
.js-calendar-graph,
.calendar-graph,
.ContributionCalendar,
.ContributionCalendar-grid,
.calendar-graph-box,
.contrib-column,
.contrib-number,
.contrib-legend,
.graph-canvas,
.activity-overview-box,
.Box.activity-overview-box {
  background-color: var(--matugen-bg-dark) !important;
  color: var(--matugen-fg) !important;
  border-color: var(--matugen-bg-dark) !important;
}

/* Profile README section (the .markdown-body box below profile info) */
.markdown-body,
.Box:has(> .Box-body .markdown-body),
.Box-body:has(.markdown-body) {
  background-color: var(--matugen-bg-dark) !important;
  color: var(--matugen-fg) !important;
  border-color: var(--matugen-bg-dark) !important;
}

/* The <pre><code> ASCII art block inside the README
 * (wrapped in .snippet-clipboard-content) — blend with the README's bg-dark */
.snippet-clipboard-content pre,
.snippet-clipboard-content pre code,
.snippet-clipboard-content code {
  background-color: var(--matugen-bg-dark) !important;
  color: var(--matugen-fg) !important;
  border-color: var(--matugen-bg-dark) !important;
}

/* Contribution activity list (the timeline on profile pages) */
.ContributionActivity,
.contribution-activity,
.js-profile-timeline-year-list,
.profile-timeline-card-wrapper,
.profile-timeline-card {
  background-color: var(--matugen-bg) !important;
  color: var(--matugen-fg) !important;
  border-color: var(--matugen-bg-light) !important;
}

/* Pinned repositories, repo cards, dashboard news blocks */
.pinned-item-list-item-content,
.dashboard-breakme,
.news,
.news .alert,
.dashboard .Box,
.dashboard .Box-row,
.dashboard .Box-header,
.js-dashboard-deferred,
.js-repos-container {
  background-color: var(--matugen-bg-dark) !important;
  color: var(--matugen-fg) !important;
  border-color: var(--matugen-bg-light) !important;
}

/* Pinned card borders blend with its bg-dark background */
.pinned-item-list-item-content {
  border-color: var(--matugen-bg-dark) !important;
}

/* Pinned card outer wrapper (.Box with padding) — fill the padding
   area with bg-dark so the card looks like a single solid surface */
.pinned-item-list-item > .Box,
.pinned-item-list-item .Box.tmp-p-3 {
  background-color: var(--matugen-bg-dark) !important;
  border-color: var(--matugen-bg-dark) !important;
}

/* Repo "card" (each pinned repo / search result row) */
.Box-row,
.col-12.d-block,
.border-bottom.color-border-muted {
  background-color: var(--matugen-bg) !important;
  color: var(--matugen-fg) !important;
  border-color: var(--matugen-bg-light) !important;
}

/* Filter chips / topic tags */
.topic-tag,
.topic,
.IssueLabel,
.label,
.Label {
  background-color: var(--matugen-bg-light) !important;
  color: var(--matugen-accent) !important;
  border-color: var(--matugen-bg-light) !important;
}

/* "Latest activity" / pinned items header */
.pinned-item-list-heading,
h2.sr-only + .Box,
h2.sr-only + * {
  background-color: transparent !important;
  color: var(--matugen-fg) !important;
}

/* Reactions count buttons (emoji +/-, comments) */
.reaction-summary-item,
.social-reaction-summary-item,
.btn-link {
  color: var(--matugen-fg-light) !important;
}

/* Issues / PR state pills (Open, Closed, Merged) */
.State,
.State--open,
.State--closed,
.State--merged,
.State--draft {
  color: var(--matugen-bg-dark) !important;
}
.State--open,
.State--draft {
  background-color: var(--matugen-tertiary) !important;
  border-color: var(--matugen-tertiary) !important;
}
.State--closed {
  background-color: #f5a3a3 !important;
  border-color: #f5a3a3 !important;
}
.State--merged {
  background-color: var(--matugen-accent) !important;
  border-color: var(--matugen-accent) !important;
}

/* ============================================================
 * CONTRIBUTION GRAPH — direct cell + SVG overrides
 * GitHub renders the contribution graph as SVG <rect> elements
 * (class="day", data-level="N") with a `fill` attribute, NOT
 * as divs with background-color. Override the SVG fill via
 * the data-level attribute, which is set on the rect by
 * GitHub's JS. Also handle the div fallback for older
 * renderers and the hover tooltip styles.
 * ============================================================ */
/* The contribution graph renders as <td data-level="N" class="ContributionCalendar-day">
 * containing a <div class="ContributionCalendar-day rounded-1 mr-1 tmp-mr-1"> that is
 * the actual visible square. The data-level attribute is on the TD only — the DIV
 * does not have it. We target both: TD via [data-level], DIV via its parent's level. */
td.ContributionCalendar-day[data-level="0"],
td.ContributionCalendar-day[data-level="0"] .ContributionCalendar-day.rounded-1,
.ContributionCalendar-day.rounded-1[data-level="0"],
rect.day[data-level="0"] {
  background-color: var(--matugen-bg-light) !important;
  fill: var(--matugen-bg-light) !important;
  stroke: var(--matugen-bg-light) !important;
}
td.ContributionCalendar-day[data-level="1"],
td.ContributionCalendar-day[data-level="1"] .ContributionCalendar-day.rounded-1,
.ContributionCalendar-day.rounded-1[data-level="1"],
rect.day[data-level="1"] {
  background-color: color-mix(in srgb, var(--matugen-accent) 25%, var(--matugen-bg)) !important;
  fill: color-mix(in srgb, var(--matugen-accent) 25%, var(--matugen-bg)) !important;
  stroke: color-mix(in srgb, var(--matugen-accent) 35%, var(--matugen-bg)) !important;
}
td.ContributionCalendar-day[data-level="2"],
td.ContributionCalendar-day[data-level="2"] .ContributionCalendar-day.rounded-1,
.ContributionCalendar-day.rounded-1[data-level="2"],
rect.day[data-level="2"] {
  background-color: color-mix(in srgb, var(--matugen-accent) 50%, var(--matugen-bg)) !important;
  fill: color-mix(in srgb, var(--matugen-accent) 50%, var(--matugen-bg)) !important;
  stroke: color-mix(in srgb, var(--matugen-accent) 60%, var(--matugen-bg)) !important;
}
td.ContributionCalendar-day[data-level="3"],
td.ContributionCalendar-day[data-level="3"] .ContributionCalendar-day.rounded-1,
.ContributionCalendar-day.rounded-1[data-level="3"],
rect.day[data-level="3"] {
  background-color: color-mix(in srgb, var(--matugen-accent) 75%, var(--matugen-bg)) !important;
  fill: color-mix(in srgb, var(--matugen-accent) 75%, var(--matugen-bg)) !important;
  stroke: color-mix(in srgb, var(--matugen-accent) 85%, var(--matugen-bg)) !important;
}
td.ContributionCalendar-day[data-level="4"],
td.ContributionCalendar-day[data-level="4"] .ContributionCalendar-day.rounded-1,
.ContributionCalendar-day.rounded-1[data-level="4"],
rect.day[data-level="4"] {
  background-color: var(--matugen-accent) !important;
  fill: var(--matugen-accent) !important;
  stroke: var(--matugen-accent) !important;
}

/* "Less ▢▢▢▢ More" legend at the bottom of the graph */
.contrib-legend .legend,
.contrib-legend .legend li,
.contrib-legend ul,
.contrib-legend li,
.contrib-legend .legend-box,
.Legend,
.Legend-item {
  background-color: transparent !important;
  color: var(--matugen-fg) !important;
  border: none !important;
}

/* Activity overview SVG (the crosshair chart "96% Commits / 4% Pull requests") */
.activity-overview-axis,
.activity-overview-point,
.activity-overview-bar,
rect.day,
rect.ContributionCalendar-day,
.contrib-column graph-rect,
.contrib-cell {
  stroke: var(--matugen-accent) !important;
  color: var(--matugen-accent) !important;
  fill: var(--matugen-accent) !important;
}

/* Month/day labels above the contribution graph */
.ContributionCalendar-label,
.ContributionCalendar-label[colspan],
table.ContributionCalendar-grid td.ContributionCalendar-label,
td.ContributionCalendar-label,
.contrib-legend,
.contrib-legend .Legend,
.contrib-legend ul li {
  color: var(--matugen-fg) !important;
  background-color: transparent !important;
  background-image: none !important;
  box-shadow: none !important;
}

/* "Show more activity" button: GitHub renders it as a full-width
 * .btn with a colored top border. Don't apply our generic .btn
 * rules (which would make it bg-light); let it be accent. */
#dashboard-show-more-activity,
.ajax-pagination-form .btn,
[data-target="pagination-full-display.btn"] {
  background-color: var(--matugen-bg-light) !important;
  color: var(--matugen-fg) !important;
  border: 1px solid var(--matugen-bg-light) !important;
}

/* Contribution progress bars (the "Created 43 commits" green bar at the right) */
.ContributionCalendar-label,
.Progress,
.Progress-item,
.Progress-bar,
.ContributionProgress {
  background-color: var(--matugen-accent) !important;
}
.Progress-item + .Progress-item {
  background-color: var(--matugen-tertiary) !important;
}

/* Selection already global; this scopes it tightly in case GitHub's
 * own ruleset tries to override with --color-canvas-subtle etc. */
::selection,
::-moz-selection {
  background-color: color-mix(in srgb, var(--matugen-accent) 70%, transparent) !important;
