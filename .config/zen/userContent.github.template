/* ============================================================
 * REPO PAGE: ISSUES/PR FILTER SEARCH BAR
 * The "Search Issues" bar with the filter expression input
 * (sort:updated-desc is:issue is:open), clear button, and
 * search submit button. The suggestions dropdown below.
 * ============================================================ */

/* Outer filter wrapper. */
[class*="Filter-module__Box_0"] {
  background-color: transparent !important;
  border: none !important;
  border-color: transparent !important;
  color: var(--matugen-fg) !important;
}

/* Filter input wrapper. */
[class*="FilterInputWrapper-module__Box_1"] {
  background-color: var(--matugen-bg-dark) !important;
  border: none !important;
  border-color: transparent !important;
  color: var(--matugen-fg) !important;
}

/* The rounded input container (left side). */
[class*="Filter-module__Box_2"] {
  background-color: var(--matugen-bg-dark) !important;
  border: none !important;
  border-color: transparent !important;
  color: var(--matugen-fg) !important;
}

/* Styled input container (the chip display). */
[class*="Input-module__Box_0"] {
  background-color: transparent !important;
  border: none !important;
  color: var(--matugen-fg) !important;
}

/* Filter expression display (sort:updated-desc is:issue is:open).
 * Must stay inline — these are <span> elements that GitHub
 * positions for the chip-style filter input. */
[class*="Input-module__Box_1"] {
  display: inline !important;
  background-color: transparent !important;
  border: none !important;
  color: var(--matugen-fg) !important;
  white-space: nowrap !important;
}
[class*="Input-module__Box_1"] [data-type="filter-expression"] {
  display: inline !important;
  background-color: transparent !important;
}
[class*="Input-module__Box_1"] [data-type="filter"] {
  display: inline !important;
  color: var(--matugen-fg-light) !important;
  background-color: transparent !important;
}
[class*="Input-module__Box_1"] [data-type="filter-value"] {
  display: inline !important;
  color: var(--matugen-accent) !important;
  background-color: transparent !important;
  font-weight: 600 !important;
}
[class*="Input-module__Box_1"] .delimiter {
  display: inline !important;
  color: var(--matugen-fg-light) !important;
  background-color: transparent !important;
}

/* Hidden input content (the actual <input> wrapper). */
[class*="Input-module__Box_2"] {
  background-color: transparent !important;
  border: none !important;
  color: var(--matugen-fg) !important;
}
/* The measurement mirror div (aria-hidden) — GitHub renders
 * it visibly for width measurement, which collides with the
 * actual input. Push it off-screen and hide it. */
[class*="Input-module__Box_3"] {
  position: absolute !important;
  top: -9999px !important;
  left: -9999px !important;
  visibility: hidden !important;
  pointer-events: none !important;
  background-color: transparent !important;
  border: none !important;
  color: var(--matugen-fg) !important;
}
[class*="Input-module__Box_4"] {
  background-color: transparent !important;
  border: none !important;
  color: var(--matugen-fg) !important;
}
[class*="Input-module__Box_4"]::placeholder {
  color: var(--matugen-fg-light) !important;
}

/* Clear button (invisible variant) — transparent, accent on hover. */
[class*="ClearButton-module__clearButton"] {
  background-color: transparent !important;
  color: var(--matugen-fg-light) !important;
  border: none !important;
  border-color: transparent !important;
  fill: var(--matugen-fg-light) !important;
}
[class*="ClearButton-module__clearButton"]:hover {
  background-color: color-mix(
    in srgb,
    var(--matugen-accent) 15%,
    transparent
  ) !important;
  color: var(--matugen-accent) !important;
  border-color: transparent !important;
  fill: var(--matugen-accent) !important;
}

/* Search submit button (default variant) — bg-dark, no border. */
[class*="SubmitButton-module__IconButton_0"],
[class*="SubmitButton-module__IconButton"] {
  background-color: var(--matugen-bg-dark) !important;
  color: var(--matugen-fg) !important;
  border: none !important;
  border-color: transparent !important;
  fill: var(--matugen-fg) !important;
}
[class*="SubmitButton-module__IconButton_0"]:hover,
[class*="SubmitButton-module__IconButton"]:hover {
  background-color: color-mix(
    in srgb,
    var(--matugen-accent) 15%,
    var(--matugen-bg-dark)
  ) !important;
  color: var(--matugen-accent) !important;
  border-color: transparent !important;
  fill: var(--matugen-accent) !important;
}

/* Suggestions dropdown (appears when typing). */
[class*="SuggestionsList-module__Box_1"],
[class*="SuggestionsList-module__Box_3"] {
  background-color: var(--matugen-bg-dark) !important;
  border: none !important;
  border-color: transparent !important;
  color: var(--matugen-fg) !important;
}
[class*="SuggestionsList-module__ActionList"],
[class*="SuggestionsList-module__ActionList_0"] {
  background-color: var(--matugen-bg-dark) !important;
  border: none !important;
  border-color: transparent !important;
  color: var(--matugen-fg) !important;
}
[class*="SuggestionsList-module__ActionList"] [class*="prc-ActionList-Item"],
[class*="SuggestionsList-module__ActionList_0"] [class*="prc-ActionList-Item"] {
  background-color: transparent !important;
  color: var(--matugen-fg) !important;
  border: none !important;
}
[class*="SuggestionsList-module__ActionList"] [class*="prc-ActionList-Item"]:hover,
[class*="SuggestionsList-module__ActionList_0"] [class*="prc-ActionList-Item"]:hover {
  background-color: color-mix(
    in srgb,
    var(--matugen-accent) 15%,
    var(--matugen-bg-dark)
  ) !important;
  color: var(--matugen-accent) !important;
}
}
