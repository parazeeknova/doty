# Zathura configuration rendered by wabi switcher from matugen colors.
# Do not edit this file directly — edit zathurarc.template instead.

set default-fg "#eae1d4"
set default-bg "#16130b"

# Completion colors
set completion-fg "#eae1d4"
set completion-bg "#231f17"
set completion-group-fg "#e4c36c"
set completion-group-bg "#231f17"
set completion-highlight-fg "#16130b"
set completion-highlight-bg "#e4c36c"

# Input bar colors
set inputbar-fg "#eae1d4"
set inputbar-bg "#231f17"

# Notification colors
set notification-fg "#eae1d4"
set notification-bg "#231f17"
set notification-error-fg "#ffb4ab"
set notification-error-bg "#231f17"
set notification-warning-fg "#adcfad"
set notification-warning-bg "#231f17"

# Tab colors
set tabbar-fg "#eae1d4"
set tabbar-bg "#231f17"
set tabbar-focus-fg "#eae1d4"
set tabbar-focus-bg "#e4c36c"

# Status bar colors
set statusbar-fg "#eae1d4"
set statusbar-bg "#231f17"

# Highlight colors
set highlight-color "#d5c5a0"
set highlight-active-color "#e4c36c"

# Recolor options (for dark mode reading)
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#16130b"
set recolor-darkcolor "#eae1d4"
