# Zathura configuration rendered by wabi switcher from matugen colors.
# Do not edit this file directly — edit zathurarc.template instead.

set default-fg "#eee0d4"
set default-bg "#18120c"

# Completion colors
set completion-fg "#eee0d4"
set completion-bg "#251e17"
set completion-group-fg "#f8bb71"
set completion-group-bg "#251e17"
set completion-highlight-fg "#18120c"
set completion-highlight-bg "#f8bb71"

# Input bar colors
set inputbar-fg "#eee0d4"
set inputbar-bg "#251e17"

# Notification colors
set notification-fg "#eee0d4"
set notification-bg "#251e17"
set notification-error-fg "#ffb4ab"
set notification-error-bg "#251e17"
set notification-warning-fg "#bbcd9e"
set notification-warning-bg "#251e17"

# Tab colors
set tabbar-fg "#eee0d4"
set tabbar-bg "#251e17"
set tabbar-focus-fg "#eee0d4"
set tabbar-focus-bg "#f8bb71"

# Status bar colors
set statusbar-fg "#eee0d4"
set statusbar-bg "#251e17"

# Highlight colors
set highlight-color "#dfc2a2"
set highlight-active-color "#f8bb71"

# Recolor options (for dark mode reading)
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#18120c"
set recolor-darkcolor "#eee0d4"
