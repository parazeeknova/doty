# Zathura configuration rendered by wabi switcher from matugen colors.
# Do not edit this file directly — edit zathurarc.template instead.

set default-fg "#e1e4d9"
set default-bg "#11140f"

# Completion colors
set completion-fg "#e1e4d9"
set completion-bg "#1d211a"
set completion-group-fg "#a9d292"
set completion-group-bg "#1d211a"
set completion-highlight-fg "#11140f"
set completion-highlight-bg "#a9d292"

# Input bar colors
set inputbar-fg "#e1e4d9"
set inputbar-bg "#1d211a"

# Notification colors
set notification-fg "#e1e4d9"
set notification-bg "#1d211a"
set notification-error-fg "#ffb4ab"
set notification-error-bg "#1d211a"
set notification-warning-fg "#a0cfd0"
set notification-warning-bg "#1d211a"

# Tab colors
set tabbar-fg "#e1e4d9"
set tabbar-bg "#1d211a"
set tabbar-focus-fg "#e1e4d9"
set tabbar-focus-bg "#a9d292"

# Status bar colors
set statusbar-fg "#e1e4d9"
set statusbar-bg "#1d211a"

# Highlight colors
set highlight-color "#bccbb0"
set highlight-active-color "#a9d292"

# Recolor options (for dark mode reading)
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#11140f"
set recolor-darkcolor "#e1e4d9"
