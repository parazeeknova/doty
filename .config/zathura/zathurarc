# Zathura configuration rendered by wabi switcher from matugen colors.
# Do not edit this file directly — edit zathurarc.template instead.

set default-fg "#e0e4da"
set default-bg "#11140f"

# Completion colors
set completion-fg "#e0e4da"
set completion-bg "#1d211b"
set completion-group-fg "#a4d397"
set completion-group-bg "#1d211b"
set completion-highlight-fg "#11140f"
set completion-highlight-bg "#a4d397"

# Input bar colors
set inputbar-fg "#e0e4da"
set inputbar-bg "#1d211b"

# Notification colors
set notification-fg "#e0e4da"
set notification-bg "#1d211b"
set notification-error-fg "#ffb4ab"
set notification-error-bg "#1d211b"
set notification-warning-fg "#a0cfd3"
set notification-warning-bg "#1d211b"

# Tab colors
set tabbar-fg "#e0e4da"
set tabbar-bg "#1d211b"
set tabbar-focus-fg "#e0e4da"
set tabbar-focus-bg "#a4d397"

# Status bar colors
set statusbar-fg "#e0e4da"
set statusbar-bg "#1d211b"

# Highlight colors
set highlight-color "#bbccb2"
set highlight-active-color "#a4d397"

# Recolor options (for dark mode reading)
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#11140f"
set recolor-darkcolor "#e0e4da"
