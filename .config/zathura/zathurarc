# Zathura configuration rendered by wabi switcher from matugen colors.
# Do not edit this file directly — edit zathurarc.template instead.

set default-fg "#e6e1e9"
set default-bg "#141318"

# Completion colors
set completion-fg "#e6e1e9"
set completion-bg "#201f24"
set completion-group-fg "#cbbeff"
set completion-group-bg "#201f24"
set completion-highlight-fg "#141318"
set completion-highlight-bg "#cbbeff"

# Input bar colors
set inputbar-fg "#e6e1e9"
set inputbar-bg "#201f24"

# Notification colors
set notification-fg "#e6e1e9"
set notification-bg "#201f24"
set notification-error-fg "#ffb4ab"
set notification-error-bg "#201f24"
set notification-warning-fg "#eeb8cb"
set notification-warning-bg "#201f24"

# Tab colors
set tabbar-fg "#e6e1e9"
set tabbar-bg "#201f24"
set tabbar-focus-fg "#e6e1e9"
set tabbar-focus-bg "#cbbeff"

# Status bar colors
set statusbar-fg "#e6e1e9"
set statusbar-bg "#201f24"

# Highlight colors
set highlight-color "#cac3dc"
set highlight-active-color "#cbbeff"

# Recolor options (for dark mode reading)
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#141318"
set recolor-darkcolor "#e6e1e9"
