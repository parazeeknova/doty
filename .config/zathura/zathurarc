# Zathura configuration rendered by wabi switcher from matugen colors.
# Do not edit this file directly — edit zathurarc.template instead.

set default-fg "#dee4de"
set default-bg "#0f1512"

# Completion colors
set completion-fg "#dee4de"
set completion-bg "#1b211e"
set completion-group-fg "#8cd5b4"
set completion-group-bg "#1b211e"
set completion-highlight-fg "#0f1512"
set completion-highlight-bg "#8cd5b4"

# Input bar colors
set inputbar-fg "#dee4de"
set inputbar-bg "#1b211e"

# Notification colors
set notification-fg "#dee4de"
set notification-bg "#1b211e"
set notification-error-fg "#ffb4ab"
set notification-error-bg "#1b211e"
set notification-warning-fg "#a6ccdf"
set notification-warning-bg "#1b211e"

# Tab colors
set tabbar-fg "#dee4de"
set tabbar-bg "#1b211e"
set tabbar-focus-fg "#dee4de"
set tabbar-focus-bg "#8cd5b4"

# Status bar colors
set statusbar-fg "#dee4de"
set statusbar-bg "#1b211e"

# Highlight colors
set highlight-color "#b3ccbe"
set highlight-active-color "#8cd5b4"

# Recolor options (for dark mode reading)
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#0f1512"
set recolor-darkcolor "#dee4de"
