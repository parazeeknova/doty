{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  },
  "permission": {
    "read": {
      "*": "allow"
    },
    "bash": "allow",
    "external_directory": {
      "/home/paper/.bun/install/cache/*": "allow",
      "/home/paper/Singulity/lumen/*": "allow",
      "/home/parazeeknova/.cargo/registry/src/*": "allow",
      "/home/parazeeknova/.config/*": "allow",
      "/home/parazeeknova/.local/share/*": "allow",
      "/home/parazeeknova/.cache/*": "allow"
    }
  }
}