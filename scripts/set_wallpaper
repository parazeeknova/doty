#!/usr/bin/env bash
PATH_TO_WALL="$1"

if [[ -z "$PATH_TO_WALL" ]]; then
    echo "Usage: $0 <path_to_wallpaper>"
    exit 1
fi

# Resolve paths to make sure they are absolute
if [[ ! "$PATH_TO_WALL" =~ ^/ ]]; then
    PATH_TO_WALL="$(realpath "$PATH_TO_WALL")"
fi

# Detect extension
EXT="${PATH_TO_WALL##*.}"
EXT="$(echo "$EXT" | tr '[:upper:]' '[:lower:]')"

if [[ "$EXT" == "mp4" || "$EXT" == "webm" ]]; then
    # Kill any existing mpvpaper instances
    killall mpvpaper 2>/dev/null
    
    # Run mpvpaper on all monitors with performance optimizations:
    # -p: auto-pauses playback when the desktop is hidden behind windows
    # -o: hardware decoding, disable scripting (media keys), disable cache, fast decoding, and GPU vo
    uwsm app -- mpvpaper -p -o "--loop --no-audio --hwdec=auto --load-scripts=no --cache=no --demuxer-max-bytes=10M --vd-lavc-fast=yes --vo=gpu" '*' "$PATH_TO_WALL"

    # Immediately pause the video wallpaper if currently on battery power to save energy
    if [[ -d /sys/class/power_supply ]]; then
        if grep -q 0 /sys/class/power_supply/*/online 2>/dev/null; then
            killall -STOP mpvpaper 2>/dev/null
        fi
    fi
else
    # Kill mpvpaper
    killall mpvpaper 2>/dev/null
    
    # Ensure awww-daemon is running
    if ! pgrep -x "awww-daemon" >/dev/null; then
        uwsm app -- awww-daemon &
        sleep 0.2
    fi
    
    # Set wallpaper via awww
    awww img "$PATH_TO_WALL"
fi
