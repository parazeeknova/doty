# Zathura configuration rendered by wabi switcher from matugen colors.
# Do not edit this file directly — edit zathurarc.template instead.

set default-fg "#1e1c13"
set default-bg "#fff9ed"

# Completion colors
set completion-fg "#1e1c13"
set completion-bg "#f4eddf"
set completion-group-fg "#6d5e0f"
set completion-group-bg "#f4eddf"
set completion-highlight-fg "#fff9ed"
set completion-highlight-bg "#6d5e0f"

# Input bar colors
set inputbar-fg "#1e1c13"
set inputbar-bg "#f4eddf"

# Notification colors
set notification-fg "#1e1c13"
set notification-bg "#f4eddf"
set notification-error-fg "#ba1a1a"
set notification-error-bg "#f4eddf"
set notification-warning-fg "#43664f"
set notification-warning-bg "#f4eddf"

# Tab colors
set tabbar-fg "#1e1c13"
set tabbar-bg "#f4eddf"
set tabbar-focus-fg "#1e1c13"
set tabbar-focus-bg "#6d5e0f"

# Status bar colors
set statusbar-fg "#1e1c13"
set statusbar-bg "#f4eddf"

# Highlight colors
set highlight-color "#665e40"
set highlight-active-color "#6d5e0f"

# Recolor options (for dark mode reading)
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#fff9ed"
set recolor-darkcolor "#1e1c13"
