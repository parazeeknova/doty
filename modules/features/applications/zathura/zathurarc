# Zathura configuration rendered by wabi switcher from matugen colors.
# Do not edit this file directly — edit zathurarc.template instead.

set default-fg "#e8e2d4"
set default-bg "#15130b"

# Completion colors
set completion-fg "#e8e2d4"
set completion-bg "#222017"
set completion-group-fg "#dac66f"
set completion-group-bg "#222017"
set completion-highlight-fg "#15130b"
set completion-highlight-bg "#dac66f"

# Input bar colors
set inputbar-fg "#e8e2d4"
set inputbar-bg "#222017"

# Notification colors
set notification-fg "#e8e2d4"
set notification-bg "#222017"
set notification-error-fg "#ffb4ab"
set notification-error-bg "#222017"
set notification-warning-fg "#a9d0b4"
set notification-warning-bg "#222017"

# Tab colors
set tabbar-fg "#e8e2d4"
set tabbar-bg "#222017"
set tabbar-focus-fg "#e8e2d4"
set tabbar-focus-bg "#dac66f"

# Status bar colors
set statusbar-fg "#e8e2d4"
set statusbar-bg "#222017"

# Highlight colors
set highlight-color "#d1c6a2"
set highlight-active-color "#dac66f"

# Recolor options (for dark mode reading)
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#15130b"
set recolor-darkcolor "#e8e2d4"
