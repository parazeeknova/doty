# Zathura configuration rendered by wabi switcher from matugen colors.
# Do not edit this file directly — edit zathurarc.template instead.

set default-fg "#e4e1e9"
set default-bg "#131318"

# Completion colors
set completion-fg "#e4e1e9"
set completion-bg "#1f1f25"
set completion-group-fg "#bcc3ff"
set completion-group-bg "#1f1f25"
set completion-highlight-fg "#131318"
set completion-highlight-bg "#bcc3ff"

# Input bar colors
set inputbar-fg "#e4e1e9"
set inputbar-bg "#1f1f25"

# Notification colors
set notification-fg "#e4e1e9"
set notification-bg "#1f1f25"
set notification-error-fg "#ffb4ab"
set notification-error-bg "#1f1f25"
set notification-warning-fg "#e6bad7"
set notification-warning-bg "#1f1f25"

# Tab colors
set tabbar-fg "#e4e1e9"
set tabbar-bg "#1f1f25"
set tabbar-focus-fg "#e4e1e9"
set tabbar-focus-bg "#bcc3ff"

# Status bar colors
set statusbar-fg "#e4e1e9"
set statusbar-bg "#1f1f25"

# Highlight colors
set highlight-color "#c4c5dd"
set highlight-active-color "#bcc3ff"

# Recolor options (for dark mode reading)
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#131318"
set recolor-darkcolor "#e4e1e9"
