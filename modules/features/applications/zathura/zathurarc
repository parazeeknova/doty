# Zathura configuration rendered by wabi switcher from matugen colors.
# Do not edit this file directly — edit zathurarc.template instead.

set default-fg "#ebdbb2"
set default-bg "#1d2021"

# Completion colors
set completion-fg "#ebdbb2"
set completion-bg "#282828"
set completion-group-fg "#a9b665"
set completion-group-bg "#282828"
set completion-highlight-fg "#1d2021"
set completion-highlight-bg "#a9b665"

# Input bar colors
set inputbar-fg "#ebdbb2"
set inputbar-bg "#282828"

# Notification colors
set notification-fg "#ebdbb2"
set notification-bg "#282828"
set notification-error-fg "#cc241d"
set notification-error-bg "#282828"
set notification-warning-fg "#d8a657"
set notification-warning-bg "#282828"

# Tab colors
set tabbar-fg "#ebdbb2"
set tabbar-bg "#282828"
set tabbar-focus-fg "#ebdbb2"
set tabbar-focus-bg "#a9b665"

# Status bar colors
set statusbar-fg "#ebdbb2"
set statusbar-bg "#282828"

# Highlight colors
set highlight-color "#7daea3"
set highlight-active-color "#a9b665"

# Recolor options (for dark mode reading)
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#1d2021"
set recolor-darkcolor "#ebdbb2"
