# Zathura configuration rendered by wabi switcher from matugen colors.
# Do not edit this file directly — edit zathurarc.template instead.

set default-fg "#eee0d5"
set default-bg "#19120c"

# Completion colors
set completion-fg "#eee0d5"
set completion-bg "#261e18"
set completion-group-fg "#fcb974"
set completion-group-bg "#261e18"
set completion-highlight-fg "#19120c"
set completion-highlight-bg "#fcb974"

# Input bar colors
set inputbar-fg "#eee0d5"
set inputbar-bg "#261e18"

# Notification colors
set notification-fg "#eee0d5"
set notification-bg "#261e18"
set notification-error-fg "#ffb4ab"
set notification-error-bg "#261e18"
set notification-warning-fg "#bfcc9b"
set notification-warning-bg "#261e18"

# Tab colors
set tabbar-fg "#eee0d5"
set tabbar-bg "#261e18"
set tabbar-focus-fg "#eee0d5"
set tabbar-focus-bg "#fcb974"

# Status bar colors
set statusbar-fg "#eee0d5"
set statusbar-bg "#261e18"

# Highlight colors
set highlight-color "#e1c1a3"
set highlight-active-color "#fcb974"

# Recolor options (for dark mode reading)
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#19120c"
set recolor-darkcolor "#eee0d5"
