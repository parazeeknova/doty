# Zathura configuration rendered by wabi switcher from matugen colors.
# Do not edit this file directly — edit zathurarc.template instead.

set default-fg "#ece1d4"
set default-bg "#17130b"

# Completion colors
set completion-fg "#ece1d4"
set completion-bg "#241f17"
set completion-group-fg "#efbf6d"
set completion-group-bg "#241f17"
set completion-highlight-fg "#17130b"
set completion-highlight-bg "#efbf6d"

# Input bar colors
set inputbar-fg "#ece1d4"
set inputbar-bg "#241f17"

# Notification colors
set notification-fg "#ece1d4"
set notification-bg "#241f17"
set notification-error-fg "#ffb4ab"
set notification-error-bg "#241f17"
set notification-warning-fg "#b4cea5"
set notification-warning-bg "#241f17"

# Tab colors
set tabbar-fg "#ece1d4"
set tabbar-bg "#241f17"
set tabbar-focus-fg "#ece1d4"
set tabbar-focus-bg "#efbf6d"

# Status bar colors
set statusbar-fg "#ece1d4"
set statusbar-bg "#241f17"

# Highlight colors
set highlight-color "#dac3a1"
set highlight-active-color "#efbf6d"

# Recolor options (for dark mode reading)
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#17130b"
set recolor-darkcolor "#ece1d4"
