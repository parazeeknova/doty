# Zathura configuration rendered by wabi switcher from matugen colors.
# Do not edit this file directly — edit zathurarc.template instead.

set default-fg "#e2e2e9"
set default-bg "#111318"

# Completion colors
set completion-fg "#e2e2e9"
set completion-bg "#1e1f25"
set completion-group-fg "#adc6ff"
set completion-group-bg "#1e1f25"
set completion-highlight-fg "#111318"
set completion-highlight-bg "#adc6ff"

# Input bar colors
set inputbar-fg "#e2e2e9"
set inputbar-bg "#1e1f25"

# Notification colors
set notification-fg "#e2e2e9"
set notification-bg "#1e1f25"
set notification-error-fg "#ffb4ab"
set notification-error-bg "#1e1f25"
set notification-warning-fg "#debcdf"
set notification-warning-bg "#1e1f25"

# Tab colors
set tabbar-fg "#e2e2e9"
set tabbar-bg "#1e1f25"
set tabbar-focus-fg "#e2e2e9"
set tabbar-focus-bg "#adc6ff"

# Status bar colors
set statusbar-fg "#e2e2e9"
set statusbar-bg "#1e1f25"

# Highlight colors
set highlight-color "#bfc6dc"
set highlight-active-color "#adc6ff"

# Recolor options (for dark mode reading)
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#111318"
set recolor-darkcolor "#e2e2e9"
