{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "matugen_bg": "{{bg}}",
    "matugen_bg_dark": "{{bg_dark}}",
    "matugen_bg_light": "{{bg_light}}",
    "matugen_fg": "{{fg}}",
    "matugen_fg_light": "{{fg_light}}",
    "matugen_accent": "{{accent}}",
    "matugen_secondary": "{{secondary}}",
    "matugen_tertiary": "{{tertiary}}",
    "matugen_error": "{{error}}"
  },
  "theme": {
    "primary":              { "dark": "matugen_accent",     "light": "matugen_accent" },
    "secondary":            { "dark": "matugen_secondary",   "light": "matugen_secondary" },
    "accent":               { "dark": "matugen_tertiary",    "light": "matugen_tertiary" },
    "error":                { "dark": "matugen_error",       "light": "matugen_error" },
    "warning":              { "dark": "matugen_tertiary",    "light": "matugen_tertiary" },
    "success":              { "dark": "matugen_accent",      "light": "matugen_accent" },
    "info":                 { "dark": "matugen_secondary",   "light": "matugen_secondary" },
    "text":                 { "dark": "matugen_fg",          "light": "matugen_fg" },
    "textMuted":            { "dark": "matugen_fg_light",    "light": "matugen_fg_light" },
    "background":           { "dark": "matugen_bg",          "light": "matugen_bg" },
    "backgroundPanel":      { "dark": "matugen_bg_dark",     "light": "matugen_bg_dark" },
    "backgroundElement":    { "dark": "matugen_bg_dark",     "light": "matugen_bg_dark" },
    "border":               { "dark": "matugen_bg_light",    "light": "matugen_bg_light" },
    "borderActive":         { "dark": "matugen_accent",      "light": "matugen_accent" },
    "borderSubtle":         { "dark": "matugen_bg_light",    "light": "matugen_bg_light" },
    "diffAdded":            { "dark": "matugen_accent",      "light": "matugen_accent" },
    "diffRemoved":          { "dark": "matugen_error",       "light": "matugen_error" },
    "diffContext":          { "dark": "matugen_fg_light",    "light": "matugen_fg_light" },
    "diffHunkHeader":       { "dark": "matugen_tertiary",    "light": "matugen_tertiary" },
    "diffHighlightAdded":   { "dark": "matugen_accent",      "light": "matugen_accent" },
    "diffHighlightRemoved": { "dark": "matugen_error",       "light": "matugen_error" },
    "diffAddedBg":          { "dark": "matugen_bg_dark",     "light": "matugen_bg_dark" },
    "diffRemovedBg":        { "dark": "matugen_bg_dark",     "light": "matugen_bg_dark" },
    "diffContextBg":        { "dark": "matugen_bg",          "light": "matugen_bg" },
    "diffLineNumber":       { "dark": "matugen_bg_light",    "light": "matugen_bg_light" },
    "diffAddedLineNumberBg":    { "dark": "matugen_bg_dark", "light": "matugen_bg_dark" },
    "diffRemovedLineNumberBg":  { "dark": "matugen_bg_dark", "light": "matugen_bg_dark" },
    "markdownText":         { "dark": "matugen_fg",          "light": "matugen_fg" },
    "markdownHeading":      { "dark": "matugen_accent",      "light": "matugen_accent" },
    "markdownLink":         { "dark": "matugen_secondary",   "light": "matugen_secondary" },
    "markdownLinkText":     { "dark": "matugen_tertiary",    "light": "matugen_tertiary" },
    "markdownCode":         { "dark": "matugen_tertiary",    "light": "matugen_tertiary" },
    "markdownBlockQuote":   { "dark": "matugen_fg_light",    "light": "matugen_fg_light" },
    "markdownEmph":         { "dark": "matugen_tertiary",    "light": "matugen_tertiary" },
    "markdownStrong":       { "dark": "matugen_accent",      "light": "matugen_accent" },
    "markdownHorizontalRule": { "dark": "matugen_bg_light",  "light": "matugen_bg_light" },
    "markdownListItem":     { "dark": "matugen_accent",      "light": "matugen_accent" },
    "markdownListEnumeration": { "dark": "matugen_tertiary", "light": "matugen_tertiary" },
    "markdownImage":        { "dark": "matugen_secondary",   "light": "matugen_secondary" },
    "markdownImageText":    { "dark": "matugen_tertiary",    "light": "matugen_tertiary" },
    "markdownCodeBlock":    { "dark": "matugen_fg",          "light": "matugen_fg" },
    "syntaxComment":        { "dark": "matugen_bg_light",    "light": "matugen_bg_light" },
    "syntaxKeyword":        { "dark": "matugen_accent",      "light": "matugen_accent" },
    "syntaxFunction":       { "dark": "matugen_accent",      "light": "matugen_accent" },
    "syntaxVariable":       { "dark": "matugen_fg",          "light": "matugen_fg" },
    "syntaxString":         { "dark": "matugen_tertiary",    "light": "matugen_tertiary" },
    "syntaxNumber":         { "dark": "matugen_secondary",   "light": "matugen_secondary" },
    "syntaxType":           { "dark": "matugen_tertiary",    "light": "matugen_tertiary" },
    "syntaxOperator":       { "dark": "matugen_accent",      "light": "matugen_accent" },
    "syntaxPunctuation":    { "dark": "matugen_fg_light",    "light": "matugen_fg_light" }
  }
}
